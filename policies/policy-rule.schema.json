{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/treesitter-use/policy-rule.schema.json",
  "title": "Policy Rule",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "description",
    "policy",
    "severity",
    "languages",
    "scope",
    "match",
    "finding"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+\\.[a-z0-9_]+\\.[a-z0-9_]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "framework",
        "category",
        "code"
      ],
      "properties": {
        "framework": {
          "type": "string",
          "enum": [
            "soc2",
            "gdpr",
            "owasp"
          ]
        },
        "category": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "code": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        }
      }
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "languages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "*",
          "go",
          "java",
          "python",
          "rust",
          "typescript",
          "javascript"
        ]
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "node_kinds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "module_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "endpoint_protocols": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "require_tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "default": {}
    },
    "match": {
      "$ref": "#/$defs/condition"
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "message",
        "primary_anchor"
      ],
      "properties": {
        "message": {
          "type": "string",
          "minLength": 1
        },
        "primary_anchor": {
          "type": "string",
          "minLength": 1
        },
        "related": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    },
    "mappings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "soc2": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "gdpr": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "owasp": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "default": {}
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "defaults": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  },
  "$defs": {
    "condition": {
      "oneOf": [
        {
          "$ref": "#/$defs/predicate"
        },
        {
          "$ref": "#/$defs/all"
        },
        {
          "$ref": "#/$defs/any"
        },
        {
          "$ref": "#/$defs/not"
        }
      ]
    },
    "predicate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fact",
        "op"
      ],
      "properties": {
        "fact": {
          "type": "string",
          "minLength": 1
        },
        "op": {
          "type": "string",
          "enum": [
            "equals",
            "not_equals",
            "in",
            "not_in",
            "contains",
            "not_contains",
            "exists",
            "not_exists",
            "matches",
            "taint_reaches"
          ]
        },
        "value": {}
      }
    },
    "all": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "all"
      ],
      "properties": {
        "all": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/condition"
          }
        }
      }
    },
    "any": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "any"
      ],
      "properties": {
        "any": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/condition"
          }
        }
      }
    },
    "not": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "not"
      ],
      "properties": {
        "not": {
          "$ref": "#/$defs/condition"
        }
      }
    }
  }
}
